	author = {Pothireddy, Sudheekar Reddy},
	year = {2025},
	note = {Place: Kohat
Publisher: Kohat University of Science and Technology (KUST)},
	keywords = {Artificial intelligence, Automation, Collaboration, Computers--Computer Networks, Empowerment, Innovations, Machine learning, Natural language processing, Organizational change, Organizations, Productivity, Software, Workflow},
