@article{alanazi_manal_influence_2025,
	title = {The {Influence} of {Artificial} {Intelligence} {Tools} on {Learning} {Outcomes} in {Computer} {Programming}: {A} {Systematic} {Review} and {Meta}-{Analysis}},
	volume = {14},
	url = {https://www.proquest.com/scholarly-journals/influence-artificial-intelligence-tools-on/docview/3211935110/se-2?accountid=11643},
	doi = {10.3390/computers14050185},
	abstract = {This systematic review and meta-analysis investigates the impact of artificial intelligence (AI) tools, including ChatGPT 3.5 and GitHub Copilot, on learning outcomes in computer programming courses. A total of 35 controlled studies published between 2020 and 2024 were analysed to assess the effectiveness of AI-assisted learning. The results indicate that students using AI tools outperformed those without such aids. The meta-analysis findings revealed that AI-assisted learning significantly reduced task completion time (SMD = \&minus;0.69, 95\% CI [\&minus;2.13, \&minus;0.74], I2 = 95\%, p = 0.34) and improved student performance scores (SMD = 0.86, 95\% CI [0.36, 1.37], p = 0.0008, I2 = 54\%). However, AI tools did not provide a statistically significant advantage in learning success or ease of understanding (SMD = 0.16, 95\% CI [\&minus;0.23, 0.55], p = 0.41, I2 = 55\%), with sensitivity analysis suggesting result variability. Student perceptions of AI tools were overwhelmingly positive, with a pooled estimate of 1.0 (95\% CI [0.92, 1.00], I2 = 0\%). While AI tools enhance computer programming proficiency and efficiency, their effectiveness depends on factors such as tool functionality and course design. To maximise benefits and mitigate over-reliance, tailored pedagogical strategies are essential. This study underscores the transformative role of AI in computer programming education and provides evidence-based insights for optimising AI-assisted learning.},
	language = {English},
	number = {5},
	journal = {Computers},
	author = {{Alanazi Manal} and Soh, Ben and {Samra Halima} and Li, Alice},
	year = {2025},
	note = {Place: Basel
Publisher: MDPI AG},
	keywords = {Artificial intelligence, artificial intelligence (AI), Boolean, Chatbots, ChatGPT, Cognition \& reasoning, Completion time, Computer programming, computer programming education, Computers, Core curriculum, Design of experiments, Education, Educational objectives, Effectiveness, Feedback, GitHub Copilot, Impact analysis, Learning, learning outcomes, meta-analysis, Meta-analysis, Performance evaluation, Problem solving, Sensitivity analysis, student engagement, Students, Systematic review, task efficiency, Tutoring},
	pages = {185},
