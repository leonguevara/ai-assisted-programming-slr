Publisher: Springer Nature B.V.},
	keywords = {Algorithms, Artificial intelligence, Artificial Intelligence and Image Processing, Automated code synthesis, Automation, Code reuse, Computer Software, Computers--Computer Networks, Datasets, Efficiency, Embedded systems, Information and Computing Sciences, Java, Machine learning, Machine learning in software development, Mathematical functions, Multilingualism, Natural language processing, Natural language programming, Productivity, Program synthesis, Programming languages, Python, Software development, Software engineering, Software engineering automation, Source code, Speech recognition, Synthesis, Task complexity, Transformer-based models},
	pages = {967},
