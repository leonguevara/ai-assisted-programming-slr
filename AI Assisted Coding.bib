Publisher: Springer Nature B.V.},
	keywords = {Artificial Intelligence and Image Processing, Computer Software, Computers, deep learning, Deep learning, Fault location, Image processing, Information and Computing Sciences, Information Systems, Maintenance, Natural language processing, software artifact representation, software benchmark, Software development, software engineering, Software engineering, Speech recognition, survey},
	pages = {111102},
