	file = {PDF:/Users/lguevara/Zotero/storage/86LTUAKX/Mastropaolo et al. - 2023 - On the Robustness of Code Generation Techniques An Empirical Study on GitHub Copilot.pdf:application/pdf},
}

@inproceedings{nguyen_empirical_2022,
