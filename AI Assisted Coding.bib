Publisher: Nature Publishing Group},
	keywords = {Bug report analysis, Code change ranking, Computer Software, Deep learning, Economic, Explainable AI, Information and Computing Sciences, Information sources, Metadata, Metric system, Optimization, Physics, Sciences: Comprehensive Works, Semantics, Software engineering, Test case prioritisation},
	pages = {1539},
