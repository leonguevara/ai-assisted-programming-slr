	month = jan,
	year = {2024},
	annote = {Snippet: … 4 Evaluation Baselines We chose some representative LLMbased software development … 2023) is a fundamental single-agent approachin LLM-driven software agents with a precise …},
	file = {PDF:files/977/Chen et al. - 2024 - Chatdev Communicative agents for software development.pdf:application/pdf},
}

