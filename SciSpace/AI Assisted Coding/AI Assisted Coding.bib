Publisher: Nature Publishing Group},
	keywords = {Ablation, ANN-ISM, Artificial intelligence, Case study, Computer Software, Cybercrime, Cybersecurity, Cybersecurity threats, Developmental stages, Economic, Empirical survey, Generative AI practices, Generative artificial intelligence, Information and Computing Sciences, Literature reviews, Malware, Multivocal literature review, Neural networks, Research methodology, Risk management, Sciences: Comprehensive Works, Security systems, Small \& medium sized enterprises-SME, Small and medium enterprises (SMEs), Software, Software development, Threats},
