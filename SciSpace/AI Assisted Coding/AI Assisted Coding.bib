	annote = {Snippet: … In this work, we present a comprehensive and systematic sur vey on LLM-based agents for … , we analyze how LLM-based agents are ap plied across different software development and …},
	file = {PDF:files/1011/Liu et al. - 2024 - Large language model-based agents for software engineering A survey.pdf:application/pdf},
}

@article{chen_survey_2024,
	title = {A survey on evaluating large language models in code generation tasks},
