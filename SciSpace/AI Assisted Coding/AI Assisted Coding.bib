Publisher: MDPI AG},
	keywords = {AI misuse, Artificial intelligence, Back propagation, Benchmarks, Chatbots, Cloning, Computers--Information Science And Information Theory, cybersecurity, Datasets, digital assistant, generative AI, Keywords, Language, large language models, Large language models, Natural language, Neural networks, Speech recognition, Task complexity, voice cloning},
