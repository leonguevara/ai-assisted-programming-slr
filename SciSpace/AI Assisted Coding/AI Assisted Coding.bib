Publisher: MDPI AG},
	keywords = {Automation, Citation analysis, Cocitation, Cognition \& reasoning, Computers--Artificial Intelligence, Design optimization, Engineering research, generative artificial intelligence, Knowledge, Language, large language model, Large language models, Literature reviews, Machine learning, Machine translation, Modular engineering, Natural language processing, Network analysis, prompt engineering, Prompt engineering, retrieval-augmented generation, Software development, software engineering, Software engineering, Software quality, Systematic review, Version control},
	pages = {206},
	annote = {Copyright - © 2025 by the authors. Licensee MDPI, Basel, Switzerland. This article is an open access article distributed under the terms and conditions of the Creative Commons Attribution (CC BY) license (https://creativecommons.org/licenses/by/4.0/). Notwithstanding the ProQuest Terms and Conditions, you may use this content in accordance with the terms of the License.},
