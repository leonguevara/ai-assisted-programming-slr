@article{sandoval_lost_2022,
	title = {Lost at c: {A} user study on the security implications of large language model code assistants},
	url = {https://www.usenix.org/conference/usenixsecurity23/presentation/sandoval},
	abstract = {Large Language Models (LLMs) such as OpenAI Codex are increasingly bei
ng used as AI-based coding assistants. Understanding the impact of the
se tools on developers' code is paramount, especially as recent work s
howed that LLMs may suggest cybersecurity vulnerabilities. We conduct
a security-driven user study (N=58) to assess code written by student
programmers when assisted by LLMs. Given the potential severity of low
-level bugs as well as their relative frequency in real-world projects
, we tasked participants with implementing a singly-linked 'shopping l
ist' structure in C. Our results indicate that the security impact in
this setting (low-level C with pointer and array manipulations) is sma
