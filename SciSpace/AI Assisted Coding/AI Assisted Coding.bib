Publisher: Springer Nature B.V.},
	keywords = {Artificial intelligence, Big Data, Chatbots, Community research, Computation, Computers--Electronic Data Processing, Human-computer interaction, Language modeling, Large language models, Microprocessors, Parallel processing, Parallel programming, Performance evaluation, Software, Software development, Task complexity, Visual programming languages, Workloads},
	pages = {161},
