	author = {Bar, Kaushik},
	month = feb,
	year = {2025},
	note = {Place: Hyderabad
Publisher: IUP Publications},
	keywords = {Artificial intelligence, Automation, Communications--Television And Cable, Cybersecurity, Large language models, Machine learning, Malware, Software, Software development, Synthesis, Telecommunications},
	pages = {75--95},
	annote = {Copyright - Copyright IUP Publications 2025},
