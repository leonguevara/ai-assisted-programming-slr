@article{li_multi-dimensional_2026,
	title = {A {Multi}-{Dimensional} {Quality} {Evaluation} of {Code} {Generated} by {LLM}-{Based} {Tools} {Across} {Multiple} {Programming} {Languages}},
	issn = {1049-331X, 1557-7392},
	url = {https://dl.acm.org/doi/10.1145/3800582},
	doi = {10.1145/3800582},
	abstract = {Large Language Model (LLM)-based code generation tools have gained widespread adoption in software development. The code quality is an important concern that affects the practical usefulness of generated code suggestions. However, comprehensive evaluations of these tools’ code quality remain limited. In this paper, we conduct a systematic comparison of five mainstream code generation tools, including GitHub Copilot, Amazon CodeWhisperer, Tongyi Lingma, Tabnine, and Codeium, across five popular programming languages (C, C++, Java, JavaScript, Python). Using 2,613 programming problems from LeetCode, we generated and analyzed 65,325 code suggestions. We then evaluate their code quality through four dimensions: functional correctness, reliability, maintainability, and complexity. Our experimental results reveal substantial performance variations across tools, languages, and quality dimensions. The overall functional correctness remains limited, with even the bestperforming tool achieving only moderate success rates. Reliability and maintainability present additional concerns, with bugs occurring more frequently in hard-difficulty tasks and code smells being pervasive across generated outputs. Although complexity is generally well-controlled, there are still outliers with excessive complexity across all tools. We believe that our study can provide valuable insights into the current state and limitations of LLM-based code generation technology. CCS Concepts: • Software and its engineering → Source code generation.},
	language = {en},
	urldate = {2026-04-06},
	journal = {ACM Transactions on Software Engineering and Methodology},
	author = {Li, Ruimeng and Mo, Ran and Zeng, Yao and Liu, Zili and Li, Zengyang and Ma, Yutao},
	month = mar,
	year = {2026},
	pages = {3800582},
	file = {PDF:files/648/Li et al. - 2026 - A Multi-Dimensional Quality Evaluation of Code Generated by LLM-Based Tools Across Multiple Programm.pdf:application/pdf},
}

